## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Uncomment if you have tasks that create the TestResults folder
# TestResults/

# Visual Studio 2019/2022 cache/options directory
.vs/

# Visual Studio for Mac
.vscode/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# DotCover
.idea/
*.dotCover

# Rider
.idea/
*.sln.iml

# Build/Packaging output
*.nupkg
*.snupkg
*.nuspec
artifacts/

# .NET Core
project.lock.json
project.fragment.lock.json
*.deps.json
*.runtimeconfig.json
*.runtimeconfig.dev.json

# VS Code settings
.vscode/

# .NET CLI
*.pidb
*.tmp

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper

# Windows image file caches
Thumbs.db
ehthumbs.db

# User-specific files
*.swp
*.bak
*.orig
*.tmp

# Rider
.idea/

# Local history for JetBrains IDEs
.idea/.idea.IC/

# Azure Functions
.local.settings.json

# Docker
**/.dockerignore
**/Dockerfile

# Logs
*.log

# Secrets
secrets.json

# Coverage and test result files
coverage/
*.coverage
*.coveragexml
*.testresults
TestResults/
